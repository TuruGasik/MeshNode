MQTT_BROKER=tcp://meshnode-mqtt:1883
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password
BRIDGE_COMMUNITY_USER=your-community-bridge-username
BRIDGE_COMMUNITY_PASS=your-community-bridge-password
BRIDGE_GLOBAL_USER=your-global-bridge-username
BRIDGE_GLOBAL_PASS=your-global-bridge-password
BRIDGE_PADANG_USER=your-padang-bridge-username
BRIDGE_PADANG_PASS=your-padang-bridge-password
RELAY_MQTT_PASSWORD=your-relay-dedup-password
TLS_DOMAIN=your-domain.example.com

# Monitor scripts (optional — used by scripts/monitor_mqtt.py and monitor_mqtt_relay.py)
# MONITOR_LOCAL_HOST=localhost
# MONITOR_LOCAL_PORT=1883
# MONITOR_LOCAL_USER=your-local-user
# MONITOR_LOCAL_PASS=your-local-pass
# MONITOR_COMMUNITY_HOST=mqtt.meshnode.id
# MONITOR_COMMUNITY_PORT=1883
# MONITOR_COMMUNITY_USER=your-community-user
# MONITOR_COMMUNITY_PASS=your-community-pass
